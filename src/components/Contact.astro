---
import { site } from '../data/site';
import { MessageCircle, Phone, MapPin, ArrowUpRight } from '@lucide/astro';
interface Props { full?: boolean; }
const { full = false } = Astro.props;
---
<section id="contact" class="section-pad bg-bone" style="position:relative; overflow:hidden;">
  <div class="glow glow-brass" style="width:40rem;height:40rem;left:-14rem;top:-10rem;" aria-hidden="true"></div>
  <div class="shell" style="position:relative; z-index:1;">
    <div class="max-w-3xl">
      {!full && (
        <>
          <p class="eyebrow fade-in">Commission</p>
          <h2 class="h-display mt-5 text-balance fade-in stagger-1" data-rise>Commission your interior.</h2>
        </>
      )}
      <p class="lead fade-in stagger-2" class:list={[!full && 'mt-6']}>
        Tell us the car and what you have in mind. Each commission is taken on directly with the atelier —
        from Dubai, for collectors and showrooms worldwide.
      </p>
    </div>

    <div class="contact-grid mt-12">
      <a href={site.whatsappHref} target="_blank" rel="noopener" class="ctile fade-in">
        <span class="ctile-ico"><MessageCircle size={22} /></span>
        <span>
          <span class="ctile-label">WhatsApp</span>
          <span class="ctile-value">Message the atelier <ArrowUpRight size={14} /></span>
        </span>
      </a>
      <a href={site.phoneHref} class="ctile fade-in stagger-1">
        <span class="ctile-ico"><Phone size={20} /></span>
        <span>
          <span class="ctile-label">Telephone</span>
          <span class="ctile-value">{site.phone}</span>
        </span>
      </a>
      <a href={site.instagramHref} target="_blank" rel="noopener" class="ctile fade-in stagger-2">
        <span class="ctile-ico">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2.5" y="2.5" width="19" height="19" rx="5.2"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.6" cy="6.4" r="1.1" fill="currentColor" stroke="none"/></svg>
        </span>
        <span>
          <span class="ctile-label">Instagram</span>
          <span class="ctile-value">{site.instagramHandle} <ArrowUpRight size={14} /></span>
        </span>
      </a>
    </div>

    <div class="contact-foot fade-in">
      <span class="inline-flex items-center gap-2"><MapPin size={16} class="text-brass-deep" />{site.addressLine}</span>
      <span class="contact-foot-note">{site.addressNote}</span>
    </div>
  </div>
</section>

<style>
  .contact-grid { display: grid; gap: 1rem; grid-template-columns: 1fr; }
  @media (min-width: 720px) { .contact-grid { grid-template-columns: repeat(3, 1fr); } }
  .ctile-label { display: block; font-family: var(--font-sans); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: rgb(var(--rgb-stone)); }
  .ctile-value { display: inline-flex; align-items: center; gap: 0.35rem; margin-top: 0.35rem; font-family: var(--font-display); font-size: 1.18rem; font-weight: 480; color: rgb(var(--rgb-ink)); }
  .contact-foot { margin-top: 2.5rem; display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem 1.4rem; padding-top: 1.6rem; border-top: 1px solid var(--hair); font-size: 0.92rem; color: rgb(var(--rgb-graphite)); }
  .contact-foot-note { color: rgb(var(--rgb-stone)); }
</style>
