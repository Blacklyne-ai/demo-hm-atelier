---
// Pinned scroll-sequence — the process, told over four full-bleed stills.
// Desktop+motion: sticky cross-fade driven by scroll. Else: stacked fallback.
import { process } from '../data/site';
const imgs = [
  '/media/work/rolls-royce-wheel.webp',
  '/media/craft/crocodile-hide.webp',
  '/media/craft/stitching.webp',
  '/media/work/bugatti-chiron.webp',
];
---
<section data-craftseq class="cseq bg-bg">
  <div class="cseq-head shell">
    <p class="eyebrow fade-in">The process</p>
    <h2 class="h-display mt-5 text-balance fade-in stagger-1">Made once, for one car.</h2>
    <p class="lead measure mt-5 fade-in stagger-2">Four stages, from the first conversation to the moment it is set into the car.</p>
  </div>

  <div class="cseq-track">
    <div class="cseq-stage shell">
      {process.map((s, i) => (
        <article class={`cseq-item ${i === 0 ? 'is-active' : ''}`} data-seq={i}>
          <div class="cseq-media">
            <img src={imgs[i]} alt={`${s.phase} — ${s.title}, HM Atelier`} loading="lazy" decoding="async" />
          </div>
          <div class="cseq-body">
            <span class="cseq-num">{s.num}</span>
            <span class="cseq-phase">{s.phase}</span>
            <h3 class="cseq-title">{s.title}</h3>
            <p class="cseq-text">{s.text}</p>
          </div>
        </article>
      ))}

      <ol class="cseq-rail" aria-hidden="true">
        {process.map((s, i) => (
          <li class={i === 0 ? 'is-active' : ''} data-seq-step={i}><span class="cseq-rail-dot"></span>{s.phase}</li>
        ))}
      </ol>
      <div class="cseq-progress"><span data-seq-fill></span></div>
    </div>
  </div>
</section>

<style>
  /* ── Fallback (no JS / reduced-motion / mobile): stacked, dark ── */
  .cseq-head { padding-top: clamp(4.5rem, 8vw, 8rem); }
  .cseq-item { display: grid; gap: 2rem; padding-block: clamp(2.5rem, 5vw, 4rem); align-items: center; }
  @media (min-width: 900px) { .cseq-item { grid-template-columns: 1.1fr 1fr; gap: 3.5rem; } .cseq-item:nth-child(even) .cseq-media { order: 2; } }
  .cseq-media { position: relative; overflow: hidden; border-radius: var(--r-lg); border: 1px solid var(--hair-soft); aspect-ratio: 16 / 11; background: rgb(var(--rgb-surface-2)); }
  .cseq-media img { width: 100%; height: 100%; object-fit: cover; }
  .cseq-num { font-family: var(--font-display); font-size: clamp(2.4rem, 5vw, 3.6rem); font-weight: 440; line-height: 1; color: rgb(var(--rgb-gold)); }
  .cseq-phase { display: block; margin-top: 0.5rem; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.22em; text-transform: uppercase; color: rgb(var(--rgb-cream-dim)); }
  .cseq-title { margin-top: 0.6rem; font-family: var(--font-display); font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 460; color: rgb(var(--rgb-cream)); }
  .cseq-text { margin-top: 0.9rem; max-width: 32rem; color: rgb(var(--rgb-cream) / 0.7); line-height: 1.7; }
  .cseq-rail, .cseq-progress { display: none; }

  /* ── Enhanced (pinned scroll-scrub, full-bleed stills) ── */
  .cseq.is-enhanced .cseq-track { height: 400vh; position: relative; }
  .cseq.is-enhanced .cseq-stage { position: sticky; top: 0; height: 100svh; max-width: none; padding: 0; overflow: hidden; }
  .cseq.is-enhanced .cseq-item { position: absolute; inset: 0; display: block; padding: 0; opacity: 0; transition: opacity 0.7s ease; }
  .cseq.is-enhanced .cseq-item.is-active { opacity: 1; }
  .cseq.is-enhanced .cseq-media { position: absolute; inset: 0; border: 0; border-radius: 0; aspect-ratio: auto; }
  .cseq.is-enhanced .cseq-media::after { content: ""; position: absolute; inset: 0; background: linear-gradient(95deg, rgb(8 7 6 / 0.9) 0%, rgb(8 7 6 / 0.55) 45%, rgb(8 7 6 / 0.15) 100%), linear-gradient(to top, rgb(8 7 6 / 0.85), transparent 55%); }
  .cseq.is-enhanced .cseq-body { position: absolute; inset-inline: 0; bottom: clamp(3rem, 8vh, 6rem); z-index: 2; width: 100%; max-width: 82rem; margin-inline: auto; padding-inline: 1.4rem; }
  @media (min-width: 768px) { .cseq.is-enhanced .cseq-body { padding-inline: 2.6rem; } }
  .cseq.is-enhanced .cseq-num { font-size: clamp(3.5rem, 9vw, 7rem); color: rgb(var(--rgb-cream)); }
  .cseq.is-enhanced .cseq-phase { color: rgb(var(--rgb-gold)); }
  .cseq.is-enhanced .cseq-title { font-size: clamp(2rem, 4.5vw, 3.4rem); }
  .cseq.is-enhanced .cseq-text { color: rgb(var(--rgb-cream) / 0.82); }

  .cseq.is-enhanced .cseq-rail { display: flex; flex-direction: column; gap: 1rem; position: absolute; right: clamp(1.5rem, 4vw, 3rem); top: 50%; transform: translateY(-50%); z-index: 3; list-style: none; }
  .cseq.is-enhanced .cseq-rail li { display: flex; align-items: center; gap: 0.7rem; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.04em; color: rgb(var(--rgb-cream) / 0.4); transition: color 0.3s ease; }
  .cseq.is-enhanced .cseq-rail li.is-active { color: rgb(var(--rgb-cream)); }
  .cseq-rail-dot { width: 7px; height: 7px; rotate: 45deg; background: rgb(var(--rgb-cream) / 0.3); transition: background 0.3s ease, box-shadow 0.3s ease; }
  .cseq.is-enhanced .cseq-rail li.is-active .cseq-rail-dot { background: rgb(var(--rgb-gold)); box-shadow: 0 0 0 4px rgb(201 168 106 / 0.18); }
  @media (max-width: 640px) { .cseq.is-enhanced .cseq-rail { display: none; } }

  .cseq.is-enhanced .cseq-progress { display: block; position: absolute; left: 0; right: 0; bottom: 0; height: 2px; background: rgb(var(--rgb-cream) / 0.14); z-index: 3; }
  .cseq.is-enhanced .cseq-progress span { display: block; height: 100%; width: 100%; transform: scaleX(0); transform-origin: left; background: rgb(var(--rgb-gold)); }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const desktop = window.matchMedia('(min-width: 768px)').matches;
  const sec = document.querySelector('[data-craftseq]');

  if (sec && !reduce && desktop) {
    gsap.registerPlugin(ScrollTrigger);
    sec.classList.add('is-enhanced');

    const items = sec.querySelectorAll('[data-seq]');
    const steps = sec.querySelectorAll('[data-seq-step]');
    const fill = sec.querySelector('[data-seq-fill]') as HTMLElement | null;
    const track = sec.querySelector('.cseq-track');
    const n = items.length;
    let cur = -1;
    const setActive = (idx: number) => {
      if (idx === cur) return;
      cur = idx;
      items.forEach((el, i) => el.classList.toggle('is-active', i === idx));
      steps.forEach((el, i) => el.classList.toggle('is-active', i <= idx));
    };
    setActive(0);

    ScrollTrigger.create({
      trigger: track,
      start: 'top top',
      end: 'bottom bottom',
      scrub: true,
      onUpdate: (self) => {
        if (fill) fill.style.transform = `scaleX(${self.progress})`;
        setActive(Math.min(n - 1, Math.floor(self.progress * n)));
      },
    });

    ScrollTrigger.refresh();
  }
</script>
