---
// The process — delicate alternating editorial rows (light, airy). No dark pin.
import { process } from '../data/site';
interface Props { bare?: boolean; }
const { bare = false } = Astro.props;
const imgs = [
  '/media/work/rolls-royce-wheel.webp',
  '/media/craft/crocodile-hide.webp',
  '/media/craft/stitching.webp',
  '/media/work/bugatti-chiron.webp',
];
---
<section id="process" class="bg-bone" class:list={[!bare && 'section-pad']} style={bare ? 'padding-block:clamp(3rem,6vw,6rem)' : undefined}>
  <div class="shell">
    {!bare && (
      <div class="max-w-3xl">
        <p class="eyebrow fade-in">The process</p>
        <h2 class="h-display mt-5 text-balance fade-in stagger-1">Made once, for one car.</h2>
        <p class="lead measure mt-6 fade-in stagger-2">Four stages, from the first conversation to the moment it is set into the car.</p>
      </div>
    )}

    <div class="proc">
      {process.map((s, i) => (
        <article class="proc-row fade-in">
          <div class="proc-media">
            <img src={imgs[i]} alt={`${s.phase} — ${s.title}, HM Atelier`} loading="lazy" decoding="async" width="800" height="1000" />
          </div>
          <div class="proc-body">
            <span class="proc-num">{s.num}</span>
            <p class="proc-phase">{s.phase}</p>
            <h3 class="h-lg mt-2">{s.title}</h3>
            <p class="lead mt-4">{s.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .proc { margin-top: clamp(3rem, 6vw, 5rem); display: grid; gap: clamp(3.5rem, 7vw, 7rem); }
  .proc-row { display: grid; gap: 2rem; align-items: center; }
  @media (min-width: 880px) {
    .proc-row { grid-template-columns: 1fr 1fr; gap: clamp(3rem, 5vw, 5.5rem); }
    .proc-row:nth-child(even) .proc-media { order: 2; }
  }
  .proc-media { overflow: hidden; border-radius: var(--r-lg); aspect-ratio: 5 / 4; background: rgb(var(--rgb-surface)); box-shadow: inset 0 0 0 1px rgb(var(--rgb-ink) / 0.06); }
  .proc-media img { width: 100%; height: 100%; object-fit: cover; transition: transform 1.1s cubic-bezier(0.22,1,0.36,1); }
  .proc-row:hover .proc-media img { transform: scale(1.04); }
  .proc-num { font-family: var(--font-display); font-size: clamp(2.6rem, 5vw, 3.8rem); font-weight: 300; line-height: 1; color: rgb(var(--rgb-brass-deep)); }
  .proc-phase { margin-top: 0.6rem; font-family: var(--font-sans); font-size: 0.7rem; font-weight: 500; letter-spacing: 0.28em; text-transform: uppercase; color: rgb(var(--rgb-stone)); }
  .proc-body .lead { max-width: 34rem; }
</style>
