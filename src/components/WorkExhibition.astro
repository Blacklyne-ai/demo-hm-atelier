---
// Full-screen cinematic exhibition — one piece per screen, dark & immersive,
// inside the light site. Elevated studio stills (Higgsfield) with slow Ken-Burns
// motion + editorial captions. Falls back to work posters if no elevated still.
import { work } from '../data/site';
interface Props { slugs?: string[]; showIntro?: boolean; }
const { slugs, showIntro = true } = Astro.props;
const featured = (slugs ?? ['bugatti-chiron', 'crocodile-console', 'ferrari-purosangue', 'porsche-911', 'mclaren-720s'])
  .map((s) => work.find((w) => w.slug === s))
  .filter(Boolean) as typeof work[number][];
const src = (slug: string) => `/media/exhibition/${slug}.webp`;
const pad = (i: number) => String(i + 1).padStart(2, '0');
---
<section class="ex" aria-label="Selected work">
  {showIntro && (
    <div class="ex-intro">
      <p class="ex-eyebrow">Selected work</p>
      <h2 class="ex-h">A few interiors that left the atelier.</h2>
    </div>
  )}

  {featured.map((w, i) => (
    <article class="ex-scene" data-ex-scene>
      <div class="ex-media">
        <img src={src(w.slug)} alt={`${w.marque} — ${w.part}, by HM Atelier`} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" data-ex-img />
      </div>
      <div class="ex-cap" class:list={[i % 2 === 1 && 'is-right']}>
        <span class="ex-num">{pad(i)} — {pad(featured.length)}</span>
        <p class="ex-marque">{w.marque}</p>
        <h3 class="ex-title">{w.part}</h3>
        <p class="ex-note">{w.note}</p>
      </div>
    </article>
  ))}
</section>

<style>
  .ex { background: #0c0a08; color: rgb(var(--rgb-bone)); }
  .ex-intro { max-width: 82rem; margin-inline: auto; padding: clamp(4.5rem, 9vw, 9rem) 1.5rem clamp(2rem, 4vw, 3.5rem); }
  @media (min-width: 768px) { .ex-intro { padding-inline: 2.75rem; } }
  .ex-eyebrow { font-family: var(--font-sans); font-size: 0.7rem; font-weight: 500; letter-spacing: 0.32em; text-transform: uppercase; color: rgb(var(--rgb-brass-lite)); }
  .ex-h { font-family: var(--font-display); font-weight: 380; font-size: clamp(2rem, 4.4vw, 3.4rem); line-height: 1.05; letter-spacing: -0.018em; color: rgb(var(--rgb-bone)); margin-top: 1.1rem; max-width: 18ch; }

  .ex-scene { position: relative; height: 92svh; min-height: 560px; overflow: hidden; }
  .ex-media { position: absolute; inset: 0; }
  .ex-media img { width: 100%; height: 100%; object-fit: cover; transform: scale(1.02); transition: transform 1.4s cubic-bezier(0.22,1,0.36,1); }
  .ex-scene[data-visible] .ex-media img { animation: kenburns 14s ease-out forwards; }
  .ex-scene::after { content: ""; position: absolute; inset: 0; pointer-events: none; background: linear-gradient(to top, rgb(12 10 8 / 0.85) 0%, rgb(12 10 8 / 0.1) 38%, transparent 60%), linear-gradient(to bottom, rgb(12 10 8 / 0.5), transparent 30%); }

  .ex-cap { position: absolute; z-index: 2; bottom: clamp(2.5rem, 6vh, 5rem); left: 0; right: 0; max-width: 82rem; margin-inline: auto; padding-inline: 1.5rem; opacity: 0; transform: translateY(24px); transition: opacity 1s ease, transform 1s cubic-bezier(0.22,1,0.36,1); }
  @media (min-width: 768px) { .ex-cap { padding-inline: 2.75rem; } }
  .ex-scene[data-visible] .ex-cap { opacity: 1; transform: translateY(0); }
  .ex-cap.is-right { text-align: right; }
  .ex-num { font-family: var(--font-sans); font-size: 0.72rem; font-weight: 500; letter-spacing: 0.28em; color: rgb(var(--rgb-bone) / 0.6); }
  .ex-marque { margin-top: 1rem; font-family: var(--font-sans); font-size: 0.74rem; font-weight: 600; letter-spacing: 0.24em; text-transform: uppercase; color: rgb(var(--rgb-brass-lite)); }
  .ex-title { font-family: var(--font-display); font-weight: 360; font-size: clamp(2rem, 5vw, 4rem); line-height: 1.04; letter-spacing: -0.02em; color: #fff; margin-top: 0.5rem; }
  .ex-note { margin-top: 0.9rem; max-width: 38ch; font-size: 0.98rem; line-height: 1.6; color: rgb(var(--rgb-bone) / 0.72); }
  .ex-cap.is-right .ex-note { margin-left: auto; }

  @keyframes kenburns { from { transform: scale(1.02); } to { transform: scale(1.1); } }
  @media (prefers-reduced-motion: reduce) { .ex-scene[data-visible] .ex-media img { animation: none; } .ex-cap { opacity: 1; transform: none; } }
</style>

<script>
  // reveal each scene + trigger Ken-Burns when it enters
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) e.target.setAttribute('data-visible', ''); });
  }, { threshold: 0.4 });
  document.querySelectorAll('[data-ex-scene]').forEach((el) => io.observe(el));
</script>
