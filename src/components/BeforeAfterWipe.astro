---
// Before→after as a scroll-driven WIPE (no video). A vertical divider sweeps across
// as you scroll, revealing the bespoke version over the factory one. Pinned.
// Used where a morph video isn't available. Graceful: shows the 'after' (no JS / reduced-motion).
interface Props { dir: string; eyebrow?: string; headline: string; beforeLabel: string; afterLabel: string; alt: string; }
const { dir, eyebrow = 'The transformation', headline, beforeLabel, afterLabel, alt } = Astro.props;
---
<section class="baw" data-baw>
  <div class="baw-stage" data-baw-stage>
    <img class="baw-img baw-base" src={`/media/${dir}/before.webp`} alt={`Factory version — ${alt}`} loading="lazy" decoding="async" />
    <img class="baw-img baw-rev" data-baw-rev src={`/media/${dir}/after.webp`} alt={alt} loading="lazy" decoding="async" />
    <span class="baw-divider" data-baw-div aria-hidden="true"></span>
    <div class="baw-scrim" aria-hidden="true"></div>
    <div class="baw-copy">
      <p class="eyebrow eyebrow--center">{eyebrow}</p>
      <h2 class="baw-h">{headline}</h2>
    </div>
    <div class="baw-labels" aria-hidden="true">
      <span class="baw-label" data-baw-before>{beforeLabel}</span>
      <span class="baw-label baw-after" data-baw-after>{afterLabel}</span>
    </div>
    <div class="baw-bar" aria-hidden="true"><span data-baw-bar></span></div>
  </div>
</section>

<style>
  .baw { background: #0c0a08; color: rgb(var(--rgb-bone)); }
  .baw-stage { position: relative; height: 100svh; min-height: 560px; overflow: hidden; background: #0c0a08; }
  .baw-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .baw-base { z-index: 1; }
  .baw-rev { z-index: 2; } /* default fully visible (after); JS sets start clip + scrubs */
  .baw-divider { position: absolute; top: 0; bottom: 0; left: 0; width: 1px; z-index: 3; background: rgb(var(--rgb-brass-lite)); box-shadow: 0 0 18px rgb(201 168 106 / 0.6); opacity: 0; }
  .baw-scrim { position: absolute; inset: 0; z-index: 4; pointer-events: none; background: radial-gradient(125% 78% at 50% 32%, transparent 42%, rgb(12 10 8 / 0.5) 100%), linear-gradient(to bottom, rgb(12 10 8 / 0.6) 0%, transparent 28%, transparent 68%, rgb(12 10 8 / 0.72) 100%); }
  .baw-copy { position: absolute; z-index: 5; top: clamp(6rem, 13vh, 8.5rem); left: 0; right: 0; text-align: center; padding-inline: 1.5rem; }
  .baw-h { font-family: var(--font-display); font-weight: 360; font-size: clamp(1.9rem, 4.4vw, 3.4rem); line-height: 1.06; letter-spacing: -0.018em; color: #fff; margin-top: 1rem; max-width: 20ch; margin-inline: auto; text-wrap: balance; text-shadow: 0 2px 30px rgb(0 0 0 / 0.5); }
  .baw-labels { position: absolute; z-index: 5; bottom: clamp(2.5rem, 6vh, 4rem); left: 0; right: 0; max-width: 82rem; margin-inline: auto; padding-inline: 1.5rem; display: flex; justify-content: space-between; }
  @media (min-width: 768px) { .baw-labels { padding-inline: 2.75rem; } }
  .baw-label { font-family: var(--font-sans); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: rgb(var(--rgb-bone) / 0.75); transition: opacity 0.4s ease; }
  .baw-after { color: rgb(var(--rgb-brass-lite)); opacity: 0.25; }
  .baw-bar { position: absolute; z-index: 5; left: 0; right: 0; bottom: 0; height: 2px; background: rgb(255 255 255 / 0.12); }
  .baw-bar span { display: block; height: 100%; width: 100%; transform: scaleX(0); transform-origin: left; background: rgb(var(--rgb-brass-lite)); }
  @media (max-width: 700px) { .baw-labels { font-size: 0.62rem; } }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reduce) gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>('[data-baw]').forEach((section) => {
    const stage = section.querySelector('[data-baw-stage]') as HTMLElement | null;
    const rev = section.querySelector('[data-baw-rev]') as HTMLElement | null;
    const div = section.querySelector('[data-baw-div]') as HTMLElement | null;
    const beforeEl = section.querySelector('[data-baw-before]') as HTMLElement | null;
    const afterEl = section.querySelector('[data-baw-after]') as HTMLElement | null;
    const barEl = section.querySelector('[data-baw-bar]') as HTMLElement | null;
    if (!stage || !rev || reduce) return;

    rev.style.clipPath = 'inset(0 100% 0 0)'; // start: only factory shown
    if (div) div.style.opacity = '1';
    ScrollTrigger.create({
      trigger: section, start: 'top top', end: '+=185%', pin: stage, pinSpacing: true, scrub: 1, invalidateOnRefresh: true,
      onUpdate: (self) => {
        const p = self.progress;
        rev.style.clipPath = `inset(0 ${(1 - p) * 100}% 0 0)`;
        if (div) div.style.left = `${p * 100}%`;
        if (barEl) barEl.style.transform = `scaleX(${p})`;
        if (beforeEl) beforeEl.style.opacity = String(Math.max(0.2, 1 - p * 1.4));
        if (afterEl) afterEl.style.opacity = String(Math.min(1, 0.25 + p * 1.3));
      },
    });
  });
  if (!reduce) ScrollTrigger.refresh();
</script>
