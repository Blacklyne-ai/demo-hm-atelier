---
// Reusable before→after scroll-scrub story (factory → bespoke). Multi-instance safe.
// Frames live in /media/<dir>/{desktop,mobile}/fNNN.webp + /media/<dir>/poster.webp
interface Props { dir: string; count: number; eyebrow?: string; headline: string; beforeLabel: string; afterLabel: string; alt: string; }
const { dir, count, eyebrow = 'The transformation', headline, beforeLabel, afterLabel, alt } = Astro.props;
---
<section class="ts" data-transform-story data-dir={dir} data-count={count}>
  <div class="ts-stage" data-ts-stage>
    <img class="ts-poster" src={`/media/${dir}/poster.webp`} alt={alt} loading="lazy" decoding="async" />
    <canvas data-ts-canvas aria-hidden="true"></canvas>
    <div class="ts-scrim" aria-hidden="true"></div>
    <div class="ts-copy">
      <p class="eyebrow eyebrow--center">{eyebrow}</p>
      <h2 class="ts-h">{headline}</h2>
    </div>
    <div class="ts-labels" aria-hidden="true">
      <span class="ts-label" data-ts-before>{beforeLabel}</span>
      <span class="ts-label ts-after" data-ts-after>{afterLabel}</span>
    </div>
    <div class="ts-bar" aria-hidden="true"><span data-ts-bar></span></div>
  </div>
</section>

<style>
  .ts { background: #0c0a08; color: rgb(var(--rgb-bone)); }
  .ts-stage { position: relative; height: 100svh; min-height: 560px; overflow: hidden; background: #0c0a08; }
  .ts-poster, .ts-stage canvas { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .ts-stage canvas { z-index: 1; }
  .ts-scrim { position: absolute; inset: 0; z-index: 2; pointer-events: none; background: radial-gradient(125% 78% at 50% 32%, transparent 40%, rgb(12 10 8 / 0.5) 100%), linear-gradient(to bottom, rgb(12 10 8 / 0.6) 0%, transparent 28%, transparent 68%, rgb(12 10 8 / 0.72) 100%); }
  .ts-copy { position: absolute; z-index: 3; top: clamp(6rem, 13vh, 8.5rem); left: 0; right: 0; text-align: center; padding-inline: 1.5rem; }
  .ts-h { font-family: var(--font-display); font-weight: 360; font-size: clamp(1.9rem, 4.4vw, 3.4rem); line-height: 1.06; letter-spacing: -0.018em; color: #fff; margin-top: 1rem; max-width: 20ch; margin-inline: auto; text-wrap: balance; text-shadow: 0 2px 30px rgb(0 0 0 / 0.5); }
  .ts-labels { position: absolute; z-index: 3; bottom: clamp(2.5rem, 6vh, 4rem); left: 0; right: 0; max-width: 82rem; margin-inline: auto; padding-inline: 1.5rem; display: flex; justify-content: space-between; }
  @media (min-width: 768px) { .ts-labels { padding-inline: 2.75rem; } }
  .ts-label { font-family: var(--font-sans); font-size: 0.7rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: rgb(var(--rgb-bone) / 0.75); transition: opacity 0.4s ease; }
  .ts-after { color: rgb(var(--rgb-brass-lite)); opacity: 0.25; }
  .ts-bar { position: absolute; z-index: 3; left: 0; right: 0; bottom: 0; height: 2px; background: rgb(255 255 255 / 0.12); }
  .ts-bar span { display: block; height: 100%; width: 100%; transform: scaleX(0); transform-origin: left; background: rgb(var(--rgb-brass-lite)); }
  @media (max-width: 700px) { .ts-labels { font-size: 0.62rem; } }
  :global(html:not(.js)) .ts-stage canvas { display: none; }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const isMobile = window.matchMedia('(max-width: 700px)').matches;
  if (!reduce) gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>('[data-transform-story]').forEach((section) => {
    const stage = section.querySelector('[data-ts-stage]') as HTMLElement | null;
    const canvas = section.querySelector('[data-ts-canvas]') as HTMLCanvasElement | null;
    if (!stage || !canvas) return;
    const COUNT = parseInt(section.dataset.count || '96', 10);
    const dir = section.dataset.dir || '';
    const base = `/media/${dir}/${isMobile ? 'mobile' : 'desktop'}`;
    const url = (i: number) => `${base}/f${String(i + 1).padStart(3, '0')}.webp`;
    const ctx = canvas.getContext('2d');
    const frames: HTMLImageElement[] = new Array(COUNT);
    const poster = new Image();
    let cur = -1, cssW = 0, cssH = 0;

    const drawCover = (img: HTMLImageElement) => {
      if (!ctx || !img.complete || !img.naturalWidth) return;
      const s = Math.max(cssW / img.naturalWidth, cssH / img.naturalHeight);
      const w = img.naturalWidth * s, h = img.naturalHeight * s;
      ctx.clearRect(0, 0, cssW, cssH);
      ctx.drawImage(img, (cssW - w) / 2, (cssH - h) / 2, w, h);
    };
    const render = (idx: number) => { const img = frames[idx]?.complete ? frames[idx] : poster; if (img && img.complete) drawCover(img); };
    const resize = () => {
      const r = canvas.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      cssW = r.width; cssH = r.height;
      canvas.width = Math.round(cssW * dpr); canvas.height = Math.round(cssH * dpr);
      ctx?.setTransform(dpr, 0, 0, dpr, 0, 0);
      render(cur < 0 ? 0 : cur);
    };
    poster.onload = resize; poster.src = `/media/${dir}/poster.webp`;
    window.addEventListener('resize', resize, { passive: true });

    let loaded = false;
    const preload = () => { if (loaded) return; loaded = true; for (let i = 0; i < COUNT; i++) { const im = new Image(); im.decoding = 'async'; im.src = url(i); frames[i] = im; } };
    const pio = new IntersectionObserver((es) => { if (es.some((e) => e.isIntersecting)) { preload(); pio.disconnect(); } }, { rootMargin: '160% 0px' });
    pio.observe(section);

    const beforeEl = section.querySelector('[data-ts-before]') as HTMLElement | null;
    const afterEl = section.querySelector('[data-ts-after]') as HTMLElement | null;
    const barEl = section.querySelector('[data-ts-bar]') as HTMLElement | null;

    if (!reduce) {
      ScrollTrigger.create({
        trigger: section, start: 'top top', end: '+=185%', pin: stage, pinSpacing: true, scrub: 1, invalidateOnRefresh: true,
        onUpdate: (self) => {
          const p = self.progress;
          const idx = Math.min(COUNT - 1, Math.max(0, Math.round(p * (COUNT - 1))));
          if (idx !== cur) { cur = idx; render(idx); }
          if (barEl) barEl.style.transform = `scaleX(${p})`;
          if (beforeEl) beforeEl.style.opacity = String(Math.max(0.2, 1 - p * 1.4));
          if (afterEl) afterEl.style.opacity = String(Math.min(1, 0.25 + p * 1.3));
        },
      });
    }
  });
  if (!reduce) ScrollTrigger.refresh();
</script>
