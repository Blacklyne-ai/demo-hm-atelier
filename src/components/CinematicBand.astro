---
// Full-bleed editorial breather — real craft still, parallax, single statement.
// Light site: a measured contrast moment. Soft warm scrim, light type.
interface Props { img?: string; statement: string; sub?: string; alt: string; align?: 'left' | 'center'; }
const { img = 'crocodile-hide', statement, sub, alt, align = 'left' } = Astro.props;
---
<section class="cine" data-parallax-wrap>
  <img class="cine-bg" src={`/media/craft/${img}.webp`} alt={alt} loading="lazy" decoding="async" data-parallax-bg />
  <div class="cine-scrim" class:list={[align === 'center' && 'is-center']} aria-hidden="true"></div>
  <div class="shell cine-inner" class:list={[align === 'center' && 'text-center']}>
    <p class="h-display text-balance cine-statement fade-in" data-rise>{statement}</p>
    {sub && <p class="lead mt-6 cine-sub fade-in stagger-1" class:list={[align === 'center' ? 'mx-auto max-w-2xl' : 'measure']}>{sub}</p>}
  </div>
</section>

<style>
  .cine { position: relative; overflow: hidden; min-height: 62svh; display: flex; align-items: center; background: rgb(var(--rgb-noir)); }
  .cine-bg { position: absolute; inset: -8% 0; width: 100%; height: 116%; object-fit: cover; z-index: 0; }
  .cine-scrim { position: absolute; inset: 0; z-index: 1; background: linear-gradient(90deg, rgb(var(--rgb-noir) / 0.78) 0%, rgb(var(--rgb-noir) / 0.42) 46%, rgb(var(--rgb-noir) / 0.12) 100%); }
  .cine-scrim.is-center { background: radial-gradient(120% 90% at 50% 50%, rgb(var(--rgb-noir) / 0.38) 0%, rgb(var(--rgb-noir) / 0.72) 100%); }
  .cine-inner { position: relative; z-index: 2; padding-block: 6rem; }
  .cine-statement { color: rgb(var(--rgb-bone)); max-width: 19ch; text-shadow: 0 2px 30px rgb(0 0 0 / 0.4); }
  .cine-inner.text-center .cine-statement { margin-inline: auto; }
  .cine-sub { color: rgb(var(--rgb-bone) / 0.86); text-shadow: 0 1px 16px rgb(0 0 0 / 0.4); }
</style>
