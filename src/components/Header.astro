---
import { nav, site } from '../data/site';
import Logo from './Logo.astro';
import { Menu, X, MessageCircle } from '@lucide/astro';
interface Props { current?: string; }
const { current = '' } = Astro.props;
const isActive = (href: string) => (href === '/' ? current === '/' : current.startsWith(href));
---
<header data-header class="site-header fixed inset-x-0 top-0 z-50 pt-3 md:pt-4">
  <div class="shell">
    <div data-navpill class="navpill glass">
      <a href="/" class="brand" aria-label={`${site.name} — home`}>
        <Logo class="h-8 w-auto md:h-9" variant="ink" />
        <span class="brand-word">HM&nbsp;Atelier</span>
      </a>

      <nav class="hidden items-center gap-8 lg:flex" aria-label="Primary">
        {nav.map((item) => (
          <a href={item.href} class:list={['nav-link', isActive(item.href) && 'is-active']}>{item.label}</a>
        ))}
      </nav>

      <div class="hidden items-center gap-3 lg:flex">
        <a href="/ar" class="lang-switch" aria-label="Switch language">
          <span class="is-on">EN</span><span class="lang-sep">/</span><span lang="ar">ع</span>
        </a>
        <a href="/contact" class="btn btn-gold" data-magnetic>Commission</a>
      </div>

      <div class="flex items-center gap-1.5 lg:hidden">
        <a href="/ar" class="lang-switch" aria-label="Switch language"><span class="is-on">EN</span><span class="lang-sep">/</span><span lang="ar">ع</span></a>
        <button data-menu-open class="icon-btn" aria-label="Open menu" aria-expanded="false"><Menu size={20} /></button>
      </div>
    </div>
  </div>
</header>

<div data-menu class="mobile-menu" aria-hidden="true">
  <div class="flex items-center justify-between p-5">
    <a href="/" class="brand"><Logo class="h-8 w-auto" variant="ink" /><span class="brand-word">HM&nbsp;Atelier</span></a>
    <button data-menu-close class="icon-btn" aria-label="Close menu"><X size={20} /></button>
  </div>
  <nav class="flex flex-col gap-1 px-6 pt-6" aria-label="Mobile">
    {nav.map((item) => (
      <a href={item.href} class:list={['mobile-link', isActive(item.href) && 'is-active']}>{item.label}</a>
    ))}
  </nav>
  <div class="mt-auto flex flex-col gap-3 p-6">
    <a href="/contact" class="btn btn-primary btn-lg btn-block">Commission your interior</a>
    <div class="grid grid-cols-2 gap-3">
      <a href={site.whatsappHref} target="_blank" rel="noopener" class="btn btn-ghost btn-block"><MessageCircle size={18} />WhatsApp</a>
      <a href={site.instagramHref} target="_blank" rel="noopener" class="btn btn-ghost btn-block">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2.5" y="2.5" width="19" height="19" rx="5.2"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.6" cy="6.4" r="1.1" fill="currentColor" stroke="none"/></svg>Instagram</a>
    </div>
  </div>
</div>

<style>
  .navpill {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 0.5rem 0.6rem 0.5rem 0.9rem; border-radius: var(--r-pill);
    transition: background 0.35s ease, border-color 0.35s ease, box-shadow 0.35s ease;
  }
  .site-header.is-scrolled .navpill { background: rgb(255 255 255 / 0.9); box-shadow: inset 0 0 0 1px rgb(var(--rgb-ink) / 0.07), 0 14px 40px -22px rgb(26 23 20 / 0.3); }
  @media (min-width: 768px) { .navpill { padding-left: 1.2rem; padding-right: 0.7rem; } }

  .brand { display: inline-flex; align-items: center; gap: 0.6rem; }
  .brand-word { font-family: var(--font-sans); font-size: 0.82rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: rgb(var(--rgb-ink)); }

  .nav-link { position: relative; font-family: var(--font-sans); font-size: 0.84rem; font-weight: 500; letter-spacing: 0.04em; color: rgb(var(--rgb-graphite)); padding: 0.3rem 0; transition: color 0.25s ease; }
  .nav-link:hover, .nav-link.is-active { color: rgb(var(--rgb-ink)); }
  .nav-link.is-active::after { content: ""; position: absolute; left: 0; right: 0; bottom: -4px; height: 1px; background: rgb(var(--rgb-brass)); }

  .lang-switch { display: inline-flex; align-items: center; gap: 0.35rem; font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.06em; color: rgb(var(--rgb-stone)); padding: 0.4rem 0.65rem; border: 1px solid rgb(var(--rgb-ink) / 0.16); border-radius: var(--r-pill); transition: border-color 0.25s ease; }
  .lang-switch:hover { border-color: rgb(var(--rgb-brass) / 0.5); }
  .lang-switch .is-on { color: rgb(var(--rgb-ink)); }
  .lang-switch .lang-sep { opacity: 0.4; }
  .lang-switch [lang="ar"] { font-size: 0.95rem; line-height: 1; }

  .icon-btn { display: inline-flex; align-items: center; justify-content: center; width: 44px; height: 44px; border-radius: 999px; color: rgb(var(--rgb-ink)); border: 1px solid rgb(var(--rgb-ink) / 0.16); background: transparent; transition: border-color 0.2s ease; }
  .icon-btn:hover { border-color: rgb(var(--rgb-brass)); }

  .mobile-menu { position: fixed; inset: 0; z-index: 70; display: flex; flex-direction: column; background: rgb(var(--rgb-bone)); opacity: 0; visibility: hidden; transform: translateY(-8px); transition: opacity 0.3s ease, transform 0.3s ease, visibility 0.3s; }
  .mobile-menu.is-open { opacity: 1; visibility: visible; transform: translateY(0); }
  .mobile-link { font-family: var(--font-display); font-size: 1.7rem; font-weight: 460; letter-spacing: -0.01em; color: rgb(var(--rgb-ink)); padding: 0.7rem 0; border-bottom: 1px solid var(--hair); }
  .mobile-link.is-active, .mobile-link:hover { color: rgb(var(--rgb-brass)); }
</style>

<script>
  const header = document.querySelector('[data-header]');
  if (header) {
    const onScroll = () => header.classList.toggle('is-scrolled', window.scrollY > 24);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
  const menu = document.querySelector('[data-menu]');
  const openBtn = document.querySelector('[data-menu-open]');
  const closeBtn = document.querySelector('[data-menu-close]');
  const setMenu = (open: boolean) => {
    if (!menu) return;
    menu.classList.toggle('is-open', open);
    menu.setAttribute('aria-hidden', String(!open));
    openBtn?.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  };
  openBtn?.addEventListener('click', () => setMenu(true));
  closeBtn?.addEventListener('click', () => setMenu(false));
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMenu(false)));
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape') setMenu(false); });
</script>
