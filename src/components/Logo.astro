---
// Original HM Atelier crest (Instagram profile), recolored only — never redrawn,
// background keyed out to transparent. ink = dark on light (nav/footer) · cream = on dark ·
// gold = accent seal · original = cream-ground raster (favicon source only).
// Operator-TODO: replace with high-res vector once supplied by the client.
interface Props { class?: string; variant?: 'ink' | 'cream' | 'gold' | 'original'; }
const { class: cls = 'h-9 w-auto', variant = 'ink' } = Astro.props;
const map: Record<string, string> = {
  ink: '/logo-crest-ink.png',
  cream: '/logo-crest-cream.png',
  gold: '/logo-crest-gold.png',
  original: '/logo-crest-original.png',
};
const src = map[variant] ?? map.ink;
---
<img src={src} class={cls} width="175" height="242" alt="HM Atelier" decoding="async" />
