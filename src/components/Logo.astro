---
// Original HM Atelier crest (Instagram profile), recolored only — never redrawn.
// cream = nav/footer on dark · gold = accent seal · original = cream-ground (light).
// Operator-TODO: replace with high-res vector once supplied by the client.
interface Props { class?: string; variant?: 'cream' | 'gold' | 'original'; }
const { class: cls = 'h-9 w-auto', variant = 'cream' } = Astro.props;
const src =
  variant === 'gold' ? '/logo-crest-gold.png'
  : variant === 'original' ? '/logo-crest-original.png'
  : '/logo-crest-cream.png';
---
<img src={src} class={cls} width="175" height="242" alt="HM Atelier" decoding="async" />
