---
// Signature scroll-scrub: scrolling re-skins a factory Mercedes-Maybach console
// in crocodile leather (real before → Higgsfield morph → after). Pinned canvas.
// Graceful fallback: static after-still + caption when no JS / reduced-motion.
const COUNT = 113;
---
<section data-transform class="tf" data-tf-count={COUNT}>
  <div data-tf-stage class="tf-stage">
    <img class="tf-poster" src="/media/transform/poster.webp" alt="A factory Mercedes-Maybach centre console, before HM Atelier re-skins it in crocodile leather" fetchpriority="low" decoding="async" />
    <canvas data-tf-canvas aria-hidden="true"></canvas>
    <div class="tf-scrim" aria-hidden="true"></div>

    <div class="tf-copy">
      <p class="tf-eyebrow">The transformation</p>
      <h2 class="tf-h">The same console —<br />re-skinned by hand.</h2>
      <p class="tf-sub">Scroll: factory leather becomes bespoke crocodile.</p>
    </div>

    <div class="tf-labels" aria-hidden="true">
      <span class="tf-label tf-before" data-tf-before>Factory · stock leather</span>
      <span class="tf-label tf-after" data-tf-after>HM Atelier · crocodile</span>
    </div>
    <div class="tf-bar" aria-hidden="true"><span data-tf-bar></span></div>
  </div>
</section>

<style>
  .tf { background: #0c0a08; }
  .tf-stage { position: relative; height: 100svh; overflow: hidden; background: #0c0a08; }
  .tf-poster, .tf-stage canvas { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .tf-stage canvas { z-index: 1; }
  .tf-scrim { position: absolute; inset: 0; z-index: 2; pointer-events: none; background: radial-gradient(120% 80% at 50% 36%, transparent 40%, rgb(12 10 8 / 0.55) 100%), linear-gradient(to bottom, rgb(12 10 8 / 0.5) 0%, transparent 26%, transparent 70%, rgb(12 10 8 / 0.7) 100%); }

  .tf-copy { position: absolute; z-index: 3; top: clamp(6rem, 14vh, 9rem); left: 0; right: 0; text-align: center; padding-inline: 1.5rem; }
  .tf-eyebrow { font-family: var(--font-sans); font-size: 0.7rem; font-weight: 500; letter-spacing: 0.32em; text-transform: uppercase; color: rgb(var(--rgb-brass-lite)); }
  .tf-h { font-family: var(--font-display); font-weight: 360; font-size: clamp(1.9rem, 4.4vw, 3.4rem); line-height: 1.06; letter-spacing: -0.018em; color: #fff; margin-top: 1rem; text-shadow: 0 2px 30px rgb(0 0 0 / 0.5); }
  .tf-sub { margin-top: 1rem; font-family: var(--font-sans); font-size: 0.8rem; font-weight: 500; letter-spacing: 0.16em; text-transform: uppercase; color: rgb(var(--rgb-bone) / 0.7); }

  .tf-labels { position: absolute; z-index: 3; bottom: clamp(2.5rem, 6vh, 4rem); left: 0; right: 0; max-width: 82rem; margin-inline: auto; padding-inline: 1.5rem; display: flex; justify-content: space-between; }
  @media (min-width: 768px) { .tf-labels { padding-inline: 2.75rem; } }
  .tf-label { font-family: var(--font-sans); font-size: 0.72rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; transition: opacity 0.4s ease, color 0.4s ease; }
  .tf-before { color: rgb(var(--rgb-bone) / 0.75); }
  .tf-after { color: rgb(var(--rgb-brass-lite)); opacity: 0.25; }

  .tf-bar { position: absolute; z-index: 3; left: 0; right: 0; bottom: 0; height: 2px; background: rgb(255 255 255 / 0.12); }
  .tf-bar span { display: block; height: 100%; width: 100%; transform: scaleX(0); transform-origin: left; background: rgb(var(--rgb-brass-lite)); }

  /* no-JS / reduced-motion: poster stays (the 'before'); copy readable */
  :global(html:not(.js)) .tf-stage canvas { display: none; }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  const section = document.querySelector('[data-transform]') as HTMLElement | null;
  const stage = document.querySelector('[data-tf-stage]') as HTMLElement | null;
  const canvas = document.querySelector('[data-tf-canvas]') as HTMLCanvasElement | null;
  if (section && stage && canvas) {
    const COUNT = parseInt(section.dataset.tfCount || '113', 10);
    const ctx = canvas.getContext('2d');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isMobile = window.matchMedia('(max-width: 700px)').matches;
    const dir = isMobile ? '/media/transform/mobile' : '/media/transform/desktop';
    const url = (i: number) => `${dir}/f${String(i + 1).padStart(3, '0')}.webp`;
    const frames: HTMLImageElement[] = new Array(COUNT);
    const poster = new Image();
    let cur = -1, cssW = 0, cssH = 0;

    const drawCover = (img: HTMLImageElement) => {
      if (!ctx || !img.complete || !img.naturalWidth) return;
      const s = Math.max(cssW / img.naturalWidth, cssH / img.naturalHeight);
      const w = img.naturalWidth * s, h = img.naturalHeight * s;
      ctx.clearRect(0, 0, cssW, cssH);
      ctx.drawImage(img, (cssW - w) / 2, (cssH - h) / 2, w, h);
    };
    const render = (idx: number) => {
      const img = frames[idx] && frames[idx].complete ? frames[idx] : poster;
      if (img && img.complete) drawCover(img);
    };
    const resize = () => {
      const r = canvas.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      cssW = r.width; cssH = r.height;
      canvas.width = Math.round(cssW * dpr); canvas.height = Math.round(cssH * dpr);
      ctx?.setTransform(dpr, 0, 0, dpr, 0, 0);
      render(cur < 0 ? 0 : cur);
    };
    poster.onload = resize; poster.src = '/media/transform/poster.webp';
    window.addEventListener('resize', resize, { passive: true });

    let preloaded = false;
    const preload = () => { if (preloaded) return; preloaded = true; for (let i = 0; i < COUNT; i++) { const im = new Image(); im.decoding = 'async'; im.src = url(i); frames[i] = im; } };
    // lazy: only fetch frames as the section approaches (5 exhibition screens of runway above)
    const pio = new IntersectionObserver((es) => { if (es.some((e) => e.isIntersecting)) { preload(); pio.disconnect(); } }, { rootMargin: '150% 0px' });
    pio.observe(section);

    const beforeEl = section.querySelector('[data-tf-before]') as HTMLElement | null;
    const afterEl = section.querySelector('[data-tf-after]') as HTMLElement | null;
    const barEl = section.querySelector('[data-tf-bar]') as HTMLElement | null;

    if (!reduce) {
      gsap.registerPlugin(ScrollTrigger);
      ScrollTrigger.create({
        trigger: section, start: 'top top', end: '+=220%', pin: stage, pinSpacing: true, scrub: 1, invalidateOnRefresh: true,
        onUpdate: (self) => {
          const p = self.progress;
          const idx = Math.min(COUNT - 1, Math.max(0, Math.round(p * (COUNT - 1))));
          if (idx !== cur) { cur = idx; render(idx); }
          if (barEl) barEl.style.transform = `scaleX(${p})`;
          if (beforeEl) beforeEl.style.opacity = String(Math.max(0.2, 1 - p * 1.4));
          if (afterEl) afterEl.style.opacity = String(Math.min(1, 0.25 + p * 1.3));
        },
      });
      ScrollTrigger.refresh();
    }
  }
</script>
