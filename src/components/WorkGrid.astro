---
import { Play } from '@lucide/astro';
import { work } from '../data/site';
interface Props { items?: typeof work[number][]; limit?: number; }
const { items, limit } = Astro.props;
const list = (items ?? work).slice(0, limit ?? undefined);
---
<div class="work-grid">
  {list.map((w, i) => (
    <button
      class="work-tile fade-in"
      class:list={[`stagger-${(i % 3) + 1}`]}
      data-video={`/media/work/${w.slug}.mp4`}
      aria-label={`Play showcase — ${w.marque} ${w.part}`}
    >
      <div class="work-media">
        <img src={`/media/work/${w.slug}.webp`} width="640" height="800" loading="lazy" decoding="async"
             alt={`${w.marque} — ${w.part}, bespoke interior work by HM Atelier`} />
        <video muted loop playsinline preload="none" tabindex="-1"></video>
        <span class="work-play" aria-hidden="true"><Play size={15} fill="currentColor" /></span>
      </div>
      <div class="work-cap">
        <p class="work-marque">{w.marque}</p>
        <h3 class="work-title">{w.part}</h3>
      </div>
    </button>
  ))}
</div>

<style>
  .work-grid { display: grid; gap: 0.9rem; grid-template-columns: 1fr; }
  @media (min-width: 560px) { .work-grid { grid-template-columns: repeat(2, 1fr); gap: 1.1rem; } }
  @media (min-width: 960px) { .work-grid { grid-template-columns: repeat(3, 1fr); } }
  .work-tile { text-align: left; cursor: pointer; padding: 0; font: inherit; color: inherit; -webkit-tap-highlight-color: transparent; }
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const fine = window.matchMedia('(pointer: fine)').matches;

  document.querySelectorAll<HTMLButtonElement>('.work-tile').forEach((tile) => {
    const video = tile.querySelector('video') as HTMLVideoElement | null;
    const src = tile.dataset.video;
    if (!video || !src) return;
    let loaded = false;
    const load = () => { if (!loaded) { video.src = src; loaded = true; } };
    const play = () => {
      load();
      video.play().then(() => tile.classList.add('is-playing')).catch(() => {});
    };
    const stop = () => { video.pause(); tile.classList.remove('is-playing'); };

    if (fine && !reduce) {
      tile.addEventListener('mouseenter', play);
      tile.addEventListener('mouseleave', stop);
    }
    tile.addEventListener('click', () => {
      tile.classList.contains('is-playing') ? stop() : play();
    });
  });
</script>
