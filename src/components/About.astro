---
import { about } from '../data/site';
import Logo from './Logo.astro';
import { ArrowRight } from '@lucide/astro';
interface Props { full?: boolean; }
const { full = false } = Astro.props;
---
<section id="about" class="section-pad bg-bone">
  <div class="shell">
    <div class="about-grid">
      <div class="about-media fade-in" data-parallax-wrap>
        <img src="/media/craft/leather-cutting.webp" class="pllx" data-parallax="10"
             alt="Hands cutting and skiving leather by hand in the HM Atelier workshop, Dubai" loading="lazy" decoding="async" />
        <span class="about-seal"><Logo class="h-20 w-auto" variant="gold" /></span>
      </div>

      <div class="about-body">
        <p class="eyebrow fade-in">The atelier</p>
        <h2 class="h-display mt-5 text-balance fade-in stagger-1" data-rise>{about.name}.</h2>
        <p class="about-role fade-in stagger-1">{about.role}</p>
        {about.paras.map((p, i) => (
          <p class="lead mt-5 fade-in" class:list={[`stagger-${Math.min(i + 1, 4)}`]}>{p}</p>
        ))}
        {!full && (
          <div class="mt-8 fade-in">
            <a href="/about" class="arrow-link">More on the atelier <ArrowRight size={15} /></a>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid { display: grid; gap: 2.5rem; align-items: center; }
  @media (min-width: 960px) { .about-grid { grid-template-columns: 0.85fr 1fr; gap: 4rem; } }
  .about-media { position: relative; overflow: hidden; border-radius: var(--r-lg); border: 1px solid var(--hair); aspect-ratio: 4 / 5; background: rgb(var(--rgb-surface)); }
  .about-seal { position: absolute; bottom: 1.2rem; right: 1.2rem; z-index: 2; opacity: 0.92; filter: drop-shadow(0 6px 16px rgb(0 0 0 / 0.6)); }
  .about-role { margin-top: 0.6rem; font-family: var(--font-sans); font-size: 0.78rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: rgb(var(--rgb-brass-deep)); }
</style>
