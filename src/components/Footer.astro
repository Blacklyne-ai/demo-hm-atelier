---
import { site, nav } from '../data/site';
import Logo from './Logo.astro';
import { Phone } from '@lucide/astro';
const WA = '<svg viewBox="0 0 24 24" width="17" height="17" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.46 1.32 4.97L2 22l5.25-1.38c1.45.79 3.08 1.2 4.79 1.2 5.46 0 9.91-4.44 9.91-9.9C21.95 6.45 17.5 2 12.04 2zm0 18.15c-1.52 0-3.01-.41-4.3-1.18l-.31-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 01-1.26-4.35c0-4.54 3.7-8.23 8.25-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 012.41 5.82c0 4.54-3.7 8.23-8.25 8.23zm4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-2-1.23-.74-.66-1.24-1.48-1.38-1.73-.14-.25-.02-.38.11-.51.11-.11.25-.29.37-.43.12-.14.16-.25.25-.42.08-.16.04-.3-.02-.42-.06-.12-.56-1.34-.76-1.84-.2-.48-.4-.41-.56-.42l-.48-.01c-.16 0-.43.06-.66.31-.23.25-.86.85-.86 2.07 0 1.22.89 2.4 1.01 2.56.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.68-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28z"/></svg>';
const IG = '<svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2.5" y="2.5" width="19" height="19" rx="5.2"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.6" cy="6.4" r="1.1" fill="currentColor" stroke="none"/></svg>';
const year = new Date().getFullYear();
const chips = ['Bespoke', 'Exotic hides', 'Handcrafted in Dubai'];
---
<footer class="footer">
  <div class="footer-accent" aria-hidden="true"></div>
  <div class="shell">
    <div class="grid gap-10 border-b border-line/60 py-14 md:py-16 lg:grid-cols-12 lg:items-start lg:gap-12">
      <div class="lg:col-span-7">
        <a href="/" class="inline-flex items-center gap-3">
          <Logo class="h-12 w-auto md:h-14" variant="ink" />
          <span class="footer-word">HM&nbsp;Atelier</span>
        </a>
        <p class="mt-7 max-w-md leading-relaxed" style="color:rgb(var(--rgb-graphite))">
          Bespoke luxury automotive interiors, handcrafted in Dubai — fine leather, exotic hides and hand embroidery
          for the world's most exclusive cars.
        </p>
        <div class="mt-7 flex flex-wrap gap-2.5">
          {chips.map((c) => <span class="chip">{c}</span>)}
        </div>
      </div>

      <div class="lg:col-span-5 lg:pl-10">
        <p class="foot-head lg:text-right">Direct lines</p>
        <ul class="foot-contact">
          <li>
            <a href={site.whatsappHref} target="_blank" rel="noopener">
              <span class="fc-ico" set:html={WA}></span>
              <span class="fc-txt"><span class="fc-label">WhatsApp</span><span class="fc-val">Message the atelier</span></span>
            </a>
          </li>
          <li>
            <a href={site.phoneHref}>
              <span class="fc-ico"><Phone size={16} /></span>
              <span class="fc-txt"><span class="fc-label">Telephone</span><span class="fc-val">{site.phone}</span></span>
            </a>
          </li>
          <li>
            <a href={site.instagramHref} target="_blank" rel="noopener">
              <span class="fc-ico" set:html={IG}></span>
              <span class="fc-txt"><span class="fc-label">Instagram</span><span class="fc-val">{site.instagramHandle}</span></span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
      <nav aria-label="Explore">
        <p class="foot-head">Explore</p>
        <ul class="space-y-3">
          {nav.filter((n) => n.href !== '/').map((n) => <li><a href={n.href} class="foot-link">{n.label}</a></li>)}
        </ul>
      </nav>
      <nav aria-label="Atelier">
        <p class="foot-head">Atelier</p>
        <ul class="space-y-3">
          <li><a href="/about" class="foot-link">About Haroon</a></li>
          <li><a href="/craft" class="foot-link">The craft</a></li>
          <li><a href="/contact" class="foot-link">Commission</a></li>
          <li><a href="/ar" class="foot-link">العربية</a></li>
        </ul>
      </nav>
      <nav aria-label="Connect">
        <p class="foot-head">Connect</p>
        <ul class="space-y-3">
          <li><a href={site.instagramHref} target="_blank" rel="noopener" class="foot-link">Instagram</a></li>
          <li><a href={site.threadsHref} target="_blank" rel="noopener" class="foot-link">Threads</a></li>
          <li><a href={site.facebookHref} target="_blank" rel="noopener" class="foot-link">Facebook</a></li>
        </ul>
      </nav>
      <div>
        <p class="foot-head">Location</p>
        <ul class="space-y-3" style="color:rgb(var(--rgb-graphite))">
          <li>{site.addressLine}</li>
          <li style="color:rgb(var(--rgb-stone))">{site.addressNote}</li>
          <li style="color:rgb(var(--rgb-stone))">Worldwide commissions</li>
        </ul>
      </div>
    </div>

    <div class="flex flex-col gap-4 border-t border-line/60 py-7 text-sm md:flex-row md:items-center md:justify-between" style="color:rgb(var(--rgb-graphite))">
      <p>&copy; {year} {site.legal} · Dubai, United Arab Emirates</p>
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
        <a href="/legal" class="foot-link">Legal</a>
        <a href="/privacy" class="foot-link">Privacy</a>
        <a href="https://www.blacklyne.ai" target="_blank" rel="noopener" class="foot-link">Design: Blacklyne</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer { position: relative; background: rgb(var(--rgb-surface)); }
  .footer-accent { position: absolute; inset-block-start: 0; inset-inline: 0; height: 1px; background: linear-gradient(90deg, rgb(var(--rgb-brass)) 0%, rgb(var(--rgb-brass) / 0.12) 40%, transparent 70%); }
  .footer-word { font-family: var(--font-sans); font-size: 0.9rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: rgb(var(--rgb-ink)); }
  .foot-head { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: rgb(var(--rgb-brass-deep)); margin-bottom: 1.25rem; }
  .foot-link { color: rgb(var(--rgb-graphite)); transition: color 0.2s ease; }
  .foot-link:hover { color: rgb(var(--rgb-ink)); }
  /* ── Refined contact list (no oversized bold number) ── */
  .foot-contact { display: flex; flex-direction: column; gap: 0.65rem; }
  .foot-contact a { display: inline-flex; align-items: center; gap: 0.8rem; }
  @media (min-width: 1024px) { .foot-contact a { justify-content: flex-end; } }
  .fc-ico { display: inline-flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 999px; flex: none; color: rgb(var(--rgb-brass-deep)); background: rgb(var(--rgb-brass) / 0.1); box-shadow: inset 0 0 0 1px rgb(var(--rgb-brass) / 0.22); transition: background 0.25s ease, color 0.25s ease; }
  .fc-ico :global(svg) { display: block; }
  .foot-contact a:hover .fc-ico { background: rgb(var(--rgb-brass-deep)); color: rgb(var(--rgb-bone)); }
  .fc-txt { display: flex; flex-direction: column; line-height: 1.2; }
  @media (min-width: 1024px) { .fc-txt { order: -1; text-align: right; } }
  .fc-label { font-family: var(--font-sans); font-size: 0.64rem; font-weight: 600; letter-spacing: 0.18em; text-transform: uppercase; color: rgb(var(--rgb-stone)); }
  .fc-val { font-family: var(--font-sans); font-size: 1rem; font-weight: 500; color: rgb(var(--rgb-ink)); margin-top: 0.15rem; transition: color 0.2s ease; }
  .foot-contact a:hover .fc-val { color: rgb(var(--rgb-brass-deep)); }
</style>
