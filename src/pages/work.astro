---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import WorkExhibition from '../components/WorkExhibition.astro';
import Marquee from '../components/Marquee.astro';
import { services } from '../data/site';
import { Disc3, Armchair, PanelTop, Layers, KeyRound, Sparkles } from '@lucide/astro';
const Icons: Record<string, any> = { Disc3, Armchair, PanelTop, Layers, KeyRound, Sparkles };
const allWork = ['bugatti-chiron', 'crocodile-console', 'ferrari-purosangue', 'mclaren-720s', 'porsche-911', 'lamborghini-urus', 'rolls-royce-wheel'];
---
<Layout
  title="Work · HM Atelier"
  description="Selected bespoke automotive interior work by HM Atelier, Dubai — steering wheels, seats, consoles, key cases and embroidery for Rolls-Royce, Bugatti, Ferrari, Lamborghini, McLaren and more."
  current="/work"
>
  <PageHero
    eyebrow="Selected work"
    title="The work."
    sub="Steering wheels, seats, consoles, hides — rebuilt by hand. Each piece, shot as it deserves."
  />

  <WorkExhibition slugs={allWork} showIntro={false} />

  <section class="section-pad bg-bone">
    <div class="shell">
      <p class="eyebrow fade-in">What we make</p>
      <h2 class="h-display mt-5 text-balance fade-in stagger-1">Six things, one standard.</h2>
      <div class="svc-grid mt-12">
        {services.map((s, i) => {
          const Icon = Icons[s.icon];
          return (
            <article class="svc-card fade-in" class:list={[`stagger-${(i % 3) + 1}`]}>
              <span class="svc-ico">{Icon && <Icon size={22} />}</span>
              <h3 class="h-md mt-5">{s.title}</h3>
              <p class="mt-2 text-[0.95rem] leading-relaxed" style="color:rgb(var(--rgb-graphite))">{s.text}</p>
            </article>
          );
        })}
      </div>
      <p class="mt-10 text-sm fade-in" style="color:rgb(var(--rgb-stone))">
        Marque names denote reference works — interiors commissioned and rebuilt by the atelier. All trademarks belong to their respective owners.
      </p>
    </div>
  </section>

  <Marquee />
</Layout>

<style>
  .svc-grid { display: grid; gap: 1rem; grid-template-columns: 1fr; }
  @media (min-width: 640px) { .svc-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 960px) { .svc-grid { grid-template-columns: repeat(3, 1fr); } }
  .svc-card { padding: 1.8rem; border-radius: var(--r-lg); background: rgb(var(--rgb-surface)); box-shadow: inset 0 0 0 1px rgb(var(--rgb-ink) / 0.06); transition: box-shadow 0.4s ease, transform 0.4s ease; }
  .svc-card:hover { box-shadow: inset 0 0 0 1px rgb(var(--rgb-brass) / 0.45); transform: translateY(-3px); }
  .svc-ico { display: inline-flex; align-items: center; justify-content: center; width: 50px; height: 50px; border-radius: var(--r-md); background: rgb(var(--rgb-brass) / 0.12); color: rgb(var(--rgb-brass-deep)); box-shadow: inset 0 0 0 1px rgb(var(--rgb-brass) / 0.28); }
</style>
