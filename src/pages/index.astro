---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import TransformStory from '../components/TransformStory.astro';
import SpecStrip from '../components/SpecStrip.astro';
import SlideGallery from '../components/SlideGallery.astro';
import Marquee from '../components/Marquee.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
---
<Layout
  title="HM Atelier · Bespoke luxury automotive interiors · Dubai"
  current="/"
  heroPoster="/media/transform/poster.webp"
>
  {/* Three transformations, back to back: console (hero) → wheel → door */}
  <Hero />
  <TransformStory
    dir="transform-wheel" count={102}
    headline="The same wheel — brought to light."
    beforeLabel="Factory · emblem off" afterLabel="HM Atelier · illuminated"
    alt="A Bugatti steering wheel whose emblem is brought to light, rebuilt by HM Atelier"
  />
  <TransformStory
    dir="transform-door" count={78}
    headline="The same door — rebuilt by hand."
    beforeLabel="Factory · stock leather" afterLabel="HM Atelier · hand-embroidered"
    alt="A factory car door panel rebuilt in white leather with hand embroidery by HM Atelier"
  />

  <SpecStrip />
  <SlideGallery
    slugs={['ferrari-purosangue', 'lamborghini-urus', 'mclaren-720s', 'rolls-royce-wheel']}
    eyebrow="The craft, up close" heading="It begins with the material."
  />
  <Marquee />
  <About />
  <Contact />
</Layout>
