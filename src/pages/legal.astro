---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';
---
<Layout title="Legal notice · HM Atelier" current="/legal" noindex={true}>
  <PageHero eyebrow="Legal" title="Legal notice." />
  <section class="section-pad bg-bone" style="padding-top:0;">
    <div class="shell-narrow legal-prose fade-in">
      <h2>Operator</h2>
      <p>
        {site.name}<br />
        Bespoke automotive interior design<br />
        Dubai, United Arab Emirates
      </p>
      <p><em>Trade licence and registered details to be confirmed before launch (operator information).</em></p>

      <h2>Responsible</h2>
      <p>{site.founder} — {site.founderRole}.</p>

      <h2>Contact</h2>
      <ul>
        <li>WhatsApp / telephone: {site.phone}</li>
        <li>Instagram: <a href={site.instagramHref} target="_blank" rel="noopener">{site.instagramHandle}</a></li>
      </ul>

      <h2>Trademarks &amp; reference works</h2>
      <p>
        Marque names and logos shown on this site (Rolls-Royce, Bugatti, Ferrari, Lamborghini, McLaren, Mercedes-Benz,
        Maybach, Bentley, Porsche and others) are the property of their respective owners. They appear only to identify
        reference works — interiors commissioned by clients and rebuilt by the atelier. No affiliation, sponsorship or
        endorsement by any marque is implied.
      </p>

      <h2>Liability for content</h2>
      <p>
        The content of this site has been prepared with care. We assume no liability for the accuracy, completeness or
        timeliness of the content. Images depict the atelier's work and materials.
      </p>

      <h2>Liability for links</h2>
      <p>
        This site contains links to external sites (e.g. Instagram). We have no influence over the content of linked
        sites and accept no liability for them; responsibility rests with their respective operators.
      </p>

      <h2>Copyright</h2>
      <p>
        Photography, video and content on this site are protected. Reproduction or use outside the limits of applicable
        copyright requires the prior written consent of the atelier.
      </p>

      <p style="margin-top:2.5rem; color:rgb(var(--rgb-stone)); font-size:0.9rem;">
        Design &amp; build: <a href="https://www.blacklyne.ai" target="_blank" rel="noopener">Blacklyne</a>. Demo site —
        media sourced from the public Instagram feed pending confirmation of usage rights.
      </p>
    </div>
  </section>
</Layout>
