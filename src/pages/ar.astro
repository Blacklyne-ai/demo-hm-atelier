---
import Layout from '../layouts/Layout.astro';
import Logo from '../components/Logo.astro';
import { ArrowLeft, MessageCircle } from '@lucide/astro';
import { site } from '../data/site';
---
<Layout title="HM Atelier · النسخة العربية" current="/ar" noindex={true}>
  <section class="ar-wrap">
    <div class="shell ar-inner">
      <Logo class="h-24 w-auto mx-auto" variant="gold" />

      <div dir="rtl" lang="ar" class="ar-block">
        <h1 class="h-display mt-9">النسخة العربية قريباً</h1>
        <p class="lead mt-5 mx-auto" style="max-width:46rem;">
          نُعِدّ تجربة عربية كاملة لِـ HM Atelier — تصميم داخلي فاخر مصنوع يدويًا في دبي.
          للتواصل أو لطلب تصميم خاص، تفضّل بالتواصل معنا مباشرة.
        </p>
        <div class="mt-9 flex flex-wrap justify-center gap-3">
          <a href={site.whatsappHref} target="_blank" rel="noopener" class="btn btn-primary btn-pill btn-lg"><MessageCircle size={18} /> تواصل عبر واتساب</a>
        </div>
      </div>

      <div class="ar-en mt-12">
        <p class="label" style="color:rgb(var(--rgb-cream-dim))">In preparation</p>
        <p class="mt-3" style="color:rgb(var(--rgb-cream) / 0.7)">A full Arabic (right-to-left) version of HM Atelier is on the way.</p>
        <a href="/" class="btn btn-ghost btn-pill mt-6"><ArrowLeft size={16} /> Continue in English</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .ar-wrap { min-height: 86svh; display: flex; align-items: center; text-align: center; padding-top: 8rem; padding-bottom: 5rem; }
  .ar-inner { max-width: 56rem; }
  .ar-block { margin-top: 1rem; }
  .ar-en { padding-top: 2.5rem; border-top: 1px solid var(--hair-soft); }
</style>
